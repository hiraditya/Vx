struct Config {
    dim: i32,
    hidden_dim: i32,
    n_layers: i32,
    n_heads: i32,
    n_kv_heads: i32,
    vocab_size: i32,
    seq_len: i32
}

fn mutate_config(conf: Config) -> Config {
    conf.dim = 512;
    return conf;
}

fn main() -> i32 {
    let conf = Config {
        dim: 256,
        hidden_dim: 1024,
        n_layers: 8,
        n_heads: 8,
        n_kv_heads: 8,
        vocab_size: 32000,
        seq_len: 1024
    };
    
    let updated = mutate_config(conf);
    
    let mut ret = 0;
    // updated.dim should be 512
    if updated.dim == 512 {
        ret = 0;
    } else {
        ret = 1;
    }
    return ret;
}
