import std::string;
import std::io;

fn main() -> i32 {
    unsafe {
        let s = vx_string_from_c_str("Hello ");
        vx_string_push_c_str(s, "World!");
        
        let len = vx_string_len(s);
        vx_printf_i32("Len: %d\n", len);

        let c_str = vx_string_as_c_str(s);
        vx_printf_i32("String: %s\n", 0); // We don't have vx_printf_str yet, but we'll test the length
        
        vx_string_free_c_str(c_str);
        vx_string_drop(s);
    }
    return 0;
}

// EXPECT: Len: 12
