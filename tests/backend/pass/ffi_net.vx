extern {
  fn vx_udp_socket_bind(c_addr: *const i8) -> *mut i8;
  fn vx_udp_socket_recv(ptr: *mut i8, buffer: *mut u8, len: i64) -> i64;
  fn vx_udp_socket_send_to(ptr: *mut i8, buffer: *const u8, len: i64, c_addr: *const i8) -> i64;
  fn vx_udp_socket_drop(ptr: *mut i8) -> i32;
  fn vx_printf_i32(format: *const i8, val: i32) -> i32;
}

fn main() -> i32 {
  unsafe {
    let addr1 = "127.0.0.1:0";
    let socket1 = vx_udp_socket_bind(addr1);

    let addr2 = "127.0.0.1:0";
    let socket2 = vx_udp_socket_bind(addr2);

    vx_udp_socket_drop(socket1);
    vx_udp_socket_drop(socket2);
    vx_printf_i32("Net Success: %d
", 0);
  }
  return 0;
}
// EXPECT: Net Success: 0
