extern {
  fn vx_stdout_write(buffer: *const u8, len: i64) -> i64;
  fn vx_stderr_write(buffer: *const u8, len: i64) -> i64;
  fn vx_printf_i32(format: *const i8, val: i32) -> i32;
}

fn main() -> i32 {
  unsafe {
    let msg = "Hello Stdout!
";
    // msg is a string literal, which in Vx acts as a pointer to bytes?
    // Wait, what is the length of "Hello Stdout!\n"? 14
    vx_stdout_write(msg, 14);

    let msg2 = "Hello Stderr!
";
    vx_stderr_write(msg2, 14);

    vx_printf_i32("Stdio Success: %d
", 0);
  }
  return 0;
}
// EXPECT: Hello Stdout!
// EXPECT: Hello Stderr!
// EXPECT: Stdio Success: 0
