{
  "name": "vx-lang",
  "displayName": "Vx Language",
  "description": "Syntax highlighting and language support for Vx",
  "publisher": "hiraditya",
  "repository": {
    "type": "git",
    "url": "https://github.com/hiraditya/Vx"
  },
  "version": "0.1.1",
  "files": [
    "syntaxes",
    "language-configuration.json",
    "LICENSE"
  ],
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "vx",
        "aliases": [
          "Vx",
          "vx"
        ],
        "extensions": [
          ".vx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vx",
        "scopeName": "source.vx",
        "path": "./syntaxes/vx.tmLanguage.json"
      }
    ]
  }
}
