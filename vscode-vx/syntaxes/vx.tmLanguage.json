{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "vx",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.vx",
          "match": "\\b(import|fn|let|mut|for|in|if|else|return|spawn|on|transfer|unroll|across|match|unsafe|comptime|assert)\\b"
        },
        {
          "name": "storage.type.vx",
          "match": "\\b(struct|enum|trait|impl|extern)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.vx",
          "match": "\\b(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f16|bf16|f32|f64|bool|Topology|MemorySpace|Ref|Verified|Pinned|HardwareState)\\b"
        },
        {
          "name": "constant.language.topology.vx",
          "match": "\\b(Host|GPU|AMX|ANE|AccCore|NPU|HostDRAM|NPUHBM|LocalSRAM)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.vx",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.vx",
          "match": "\\\\."
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.vx",
          "match": "//.*$"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.vx",
          "match": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.language.boolean.vx",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.vx",
          "match": "(\\+|-|\\*|/|%|==|!=|<|>|<=|>=|=|\\+=|-=|\\*=|/=|&&|\\|\\||!)"
        }
      ]
    }
  },
  "scopeName": "source.vx"
}
